    Public Sub New(key As Byte())
        Array.Copy(PInit, P, PInit.Length)
        For i As Integer = 0 To 255
            S(0, i) = S0Init(i)
            S(1, i) = S1Init(i)
            S(2, i) = S2Init(i)
            S(3, i) = S3Init(i)
        Next
        InitializeKey(key)
    End Sub

    Public Sub EncryptBlock(buffer As Byte(), offset As Integer)
        Dim left As UInteger = ReadUInt32BigEndian(buffer, offset)
        Dim right As UInteger = ReadUInt32BigEndian(buffer, offset + 4)
        EncryptPair(left, right)
        WriteUInt32BigEndian(buffer, offset, left)
        WriteUInt32BigEndian(buffer, offset + 4, right)
    End Sub

    Public Sub DecryptBlock(buffer As Byte(), offset As Integer)
        Dim left As UInteger = ReadUInt32BigEndian(buffer, offset)
        Dim right As UInteger = ReadUInt32BigEndian(buffer, offset + 4)
        DecryptPair(left, right)
        WriteUInt32BigEndian(buffer, offset, left)
        WriteUInt32BigEndian(buffer, offset + 4, right)
    End Sub

    Private Sub InitializeKey(key As Byte())
        If key Is Nothing OrElse key.Length = 0 Then
            Throw New ArgumentException("Blowfish key is required", "key")
        End If

        Dim keyIndex As Integer = 0
        For i As Integer = 0 To P.Length - 1
            Dim data As UInteger = 0UI
            For j As Integer = 0 To 3
                data = (data << 8) Or CUInt(key(keyIndex))
                keyIndex += 1
                If keyIndex >= key.Length Then keyIndex = 0
            Next
            P(i) = P(i) Xor data
        Next

        Dim block As Byte() = New Byte(7) {}
        For i As Integer = 0 To P.Length - 1 Step 2
            EncryptBlock(block, 0)
            P(i) = ReadUInt32BigEndian(block, 0)
            P(i + 1) = ReadUInt32BigEndian(block, 4)
        Next

        For box As Integer = 0 To 3
            For i As Integer = 0 To 255 Step 2
                EncryptBlock(block, 0)
                S(box, i) = ReadUInt32BigEndian(block, 0)
                S(box, i + 1) = ReadUInt32BigEndian(block, 4)
            Next
        Next
    End Sub

    Private Sub EncryptPair(ByRef left As UInteger, ByRef right As UInteger)
        For round As Integer = 0 To 15
            left = left Xor P(round)
            right = right Xor F(left)
            Dim temp As UInteger = left
            left = right
            right = temp
        Next
        Dim swap As UInteger = left
        left = right
        right = swap
        right = right Xor P(16)
        left = left Xor P(17)
    End Sub

    Private Sub DecryptPair(ByRef left As UInteger, ByRef right As UInteger)
        For round As Integer = 17 To 2 Step -1
            left = left Xor P(round)
            right = right Xor F(left)
            Dim temp As UInteger = left
            left = right
            right = temp
        Next
        Dim swap As UInteger = left
        left = right
        right = swap
        right = right Xor P(1)
        left = left Xor P(0)
    End Sub

    Private Function F(x As UInteger) As UInteger
        Dim a As UInteger = (x >> 24) And &HFFUI
        Dim b As UInteger = (x >> 16) And &HFFUI
        Dim c As UInteger = (x >> 8) And &HFFUI
        Dim d As UInteger = x And &HFFUI
        Return AddU32(AddU32(S(0, CInt(a)), S(1, CInt(b))) Xor S(2, CInt(c)), S(3, CInt(d)))
    End Function

    Private Shared Function AddU32(left As UInteger, right As UInteger) As UInteger
        Return CUInt((CLng(left) + CLng(right)) And &HFFFFFFFFL)
    End Function

    Private Shared Function ReadUInt32BigEndian(buffer As Byte(), offset As Integer) As UInteger
        Return (CUInt(buffer(offset)) << 24) Or (CUInt(buffer(offset + 1)) << 16) Or (CUInt(buffer(offset + 2)) << 8) Or CUInt(buffer(offset + 3))
    End Function

    Private Shared Sub WriteUInt32BigEndian(buffer As Byte(), offset As Integer, value As UInteger)
        buffer(offset) = CByte((value >> 24) And &HFFUI)
        buffer(offset + 1) = CByte((value >> 16) And &HFFUI)
        buffer(offset + 2) = CByte((value >> 8) And &HFFUI)
        buffer(offset + 3) = CByte(value And &HFFUI)
    End Sub
End Class
