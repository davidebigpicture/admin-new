<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Secrets (PilotMembershipEncryptionKey, etc.) go in web.config.local — see web.config.local.example -->
  <appSettings file="web.config.local">
    <add key="PilotAllowedHost" value="dev.services.wvbps.wv.gov" />
    <add key="PilotUsers" value="dhoffman" />
    <!-- Relocatable roots: changing these (and leaving relative routes alone) moves the pilot. -->
    <add key="PilotRootPath" value="/dev/adminshell" />
    <add key="GlobalAdminRootPath" value="/admin/admin" />
    <!-- Relative to PilotRootPath / GlobalAdminRootPath -->
    <add key="PilotDefaultRoute" value="views.asp" />
    <add key="PilotRoutes" value="views.asp=views.asp|Views;loginlog.asp=loginlog.asp|Login Log;sql_logs.asp=sql_logs.asp|SQL Logs;sms_logs.asp=sms_logs.asp|SMS Logs;managed/access-manager/index.html=cgi-bin/accessadmin.pl|Access Manager" />
    <add key="PilotPasswordHashUrl" value="https://ws.ebigpicture.com/hash.aspx" />
    <add key="PilotBannerTitle" value="West Virginia Board of Physical Therapy" />
    <add key="PilotBannerType" value="Admin Shell Pilot" />
    <add key="RedisConnectionPrimary" value="redis-development.albertsonconsulting.com:6379" />
    <add key="PilotLegacyCredentialEncoder" value="perl-crypt-cbc-blowfish" />
    <add key="PilotLegacySessionTimeoutMinutes" value="60" />
    <!-- Capability ACL identities (relative to GlobalAdminRootPath) -->
    <add key="AccessManagerSectionCapability" value="cgi-bin/sectionadmin.pl" />
    <add key="AccessManagerScriptCapability" value="cgi-bin/scriptadmin.pl" />
    <add key="AccessManagerMembershipCapability" value="cgi-bin/section_scriptadmin.pl" />
    <add key="AccessManagerGrantCapability" value="cgi-bin/accessadmin.pl" />
  </appSettings>
</configuration>
